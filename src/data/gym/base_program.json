{
  "_meta": {
    "template_key": "upper_lower_upper_3day",
    "name": "3-Day Upper / Lower / Upper",
    "description": "The balanced base program. Every upper muscle hit 2x/week, legs 1x (upper-body priority by design). All exercises reference keys from exercise_catalog.json. The generator reads this, and if a specialization is active, applies specialization_rules.json on top.",
    "frequency_per_week": 3,
    "deload_interval_weeks": 7,
    "global_rules": {
      "rir_working_sets": "1-3 reps in reserve; final set of an exercise may go to ~0-1 RIR",
      "tempo": "Controlled eccentric ~2-3s, no bouncing, full range of motion",
      "progression": "Double progression: when all working sets hit the top of the rep range at target RIR, add the smallest load increment next session (2.5kg barbell, 1-2kg per dumbbell, 1 plate-pin on machines).",
      "deload": "Every 7 weeks (configurable): same exercises, ~60% of working weight, ~half the sets, 1 week, then resume."
    },
    "baseline_weekly_volume_sets": {
      "_comment": "Direct + clearly-counted sets per muscle across the whole week at program start (MEV-ish, leaves room to add). Compound presses/pulls are counted toward their prime mover only, matching RP's counting convention.",
      "chest": 9,
      "back": 9,
      "shoulders_side": 7,
      "shoulders_rear": 3,
      "shoulders_front": 3,
      "biceps": 3,
      "triceps": 3,
      "quads": 8,
      "hamstrings": 6,
      "calves": 3,
      "abs": 3
    }
  },

